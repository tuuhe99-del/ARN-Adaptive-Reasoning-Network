#!/usr/bin/env bash
# Switch ARN to a different embedding model. All memories are migrated safely.
# Usage: bash arn-switch-model [nano|small|base]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ARN_PORT=8742
ARN_DATA_DIR="${ARN_DATA_DIR:-$HOME/.arn_data}"
AGENT_DIR="$ARN_DATA_DIR/main"
PLIST_DST="$HOME/Library/LaunchAgents/com.arn.server.plist"
LOG_FILE="/tmp/arn-server.log"

# ── Helpers ───────────────────────────────────────────────────────────────────
say()  { echo "  $*"; }
ok()   { echo "  ✅ $*"; }
warn() { echo "  ⚠️  $*"; }
fail() { echo "  ❌ $*"; exit 1; }

# ── Step 1: Validate target tier ─────────────────────────────────────────────
TARGET="${1:-}"

read_current_tier() {
    local fp="$AGENT_DIR/.model_fingerprint"
    if [[ -f "$fp" ]]; then
        python3 -c "import json; d=json.load(open('$fp')); print(d.get('tier','unknown'))" 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

CURRENT_TIER="$(read_current_tier)"

if [[ -z "$TARGET" ]] || [[ "$TARGET" != "nano" && "$TARGET" != "small" && "$TARGET" != "base" ]]; then
    echo ""
    echo "  Usage: arn-switch-model [nano|small|base]"
    echo ""
    echo "  Available tiers:"
    echo "    nano   — fastest, lowest RAM (~80MB)"
    echo "    small  — balanced (~200MB)"
    echo "    base   — highest quality (~400MB)"
    echo ""
    echo "  Current tier: $CURRENT_TIER (from model fingerprint)"
    echo ""
    exit 0
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ARN Model Switch: $CURRENT_TIER → $TARGET"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ── Step 2: Check if already on that tier ────────────────────────────────────
if [[ "$CURRENT_TIER" == "$TARGET" ]]; then
    ok "Already using $TARGET model. Nothing to do."
    echo ""
    exit 0
fi

# ── Step 3: Stop the server ───────────────────────────────────────────────────
say "Stopping memory server..."
pkill -f "arn_v9.api.server" 2>/dev/null || true
sleep 2

# Confirm it stopped
if curl -sf "http://127.0.0.1:$ARN_PORT/v1/health" >/dev/null 2>&1; then
    warn "Server still responding — waiting a moment..."
    sleep 3
fi

ok "Memory server stopped"

# ── Step 4: Run migration ─────────────────────────────────────────────────────
say "Migrating memories to $TARGET model... (this may take a minute on first run)"

MIGRATE_LOG="/tmp/arn-migrate.log"

if ! PYTHONPATH="$SCRIPT_DIR" python3 -m arn_v9.scripts.migrate_to_base_tier \
    --data-root "$ARN_DATA_DIR" \
    --to-tier "$TARGET" \
    > "$MIGRATE_LOG" 2>&1; then
    echo ""
    echo "  Migration output:"
    tail -20 "$MIGRATE_LOG" | sed 's/^/    /'
    echo ""
    fail "Migration failed — check $MIGRATE_LOG for details"
fi

ok "Migration complete"

# Count memories after migration (best-effort)
MEMORY_COUNT=""
if [[ -f "$ARN_DATA_DIR/main/arn_metadata.db" ]]; then
    MEMORY_COUNT=$(python3 -c "
import sqlite3
try:
    conn = sqlite3.connect('$ARN_DATA_DIR/main/arn_metadata.db')
    row = conn.execute('SELECT COUNT(*) FROM episodes WHERE is_valid=1').fetchone()
    print(row[0] if row else 0)
except Exception:
    print('')
" 2>/dev/null || echo "")
fi

# ── Step 5: Update launchd plist ─────────────────────────────────────────────
OS="$(uname -s)"

if [[ "$OS" == "Darwin" && -f "$PLIST_DST" ]]; then
    say "Updating auto-start service..."

    # Stop the launchd job first
    launchctl unload "$PLIST_DST" 2>/dev/null || true

    # Replace all tier values in the plist EnvironmentVariables section
    # The plist has: <key>ARN_EMBEDDING_TIER</key><string>OLDTIER</string>
    /usr/bin/python3 - "$PLIST_DST" "$TARGET" << 'PYSCRIPT'
import sys, re

plist_path, new_tier = sys.argv[1], sys.argv[2]

with open(plist_path, 'r') as f:
    content = f.read()

# Replace the tier value after the ARN_EMBEDDING_TIER key
updated = re.sub(
    r'(<key>ARN_EMBEDDING_TIER</key>\s*<string>)[^<]*(</string>)',
    rf'\g<1>{new_tier}\g<2>',
    content
)

if updated == content:
    print(f"  ⚠️  Could not find ARN_EMBEDDING_TIER in plist — update manually")
else:
    with open(plist_path, 'w') as f:
        f.write(updated)
    print(f"  ✅ launchd plist updated to tier={new_tier}")
PYSCRIPT

    ok "Auto-start service updated"
elif [[ "$OS" == "Linux" ]]; then
    say "Linux: update ARN_EMBEDDING_TIER=$TARGET in your systemd unit file manually"
fi

# ── Step 6: Restart server with new tier ─────────────────────────────────────
say "Restarting memory server with $TARGET model..."

mkdir -p "$ARN_DATA_DIR"

PYTHONPATH="$SCRIPT_DIR" \
ARN_EMBEDDING_TIER="$TARGET" \
ARN_DATA_ROOT="$ARN_DATA_DIR" \
  python3 -m uvicorn arn_v9.api.server:app \
    --host 127.0.0.1 \
    --port "$ARN_PORT" \
    --workers 1 \
    >> "$LOG_FILE" 2>&1 &

SERVER_PID=$!

# Wait up to 15s for the server to respond
READY=0
for i in $(seq 1 15); do
    if curl -sf "http://127.0.0.1:$ARN_PORT/v1/health" >/dev/null 2>&1; then
        READY=1
        break
    fi
    sleep 1
done

if [[ "$READY" -eq 0 ]]; then
    fail "Server failed to start — check $LOG_FILE"
fi

ok "Memory server restarted (PID $SERVER_PID)"

# ── Step 7: Verify recall still works ────────────────────────────────────────
say "Verifying memory recall..."

API_KEY=""
if [[ -f "$ARN_DATA_DIR/.api_key" ]]; then
    API_KEY="$(cat "$ARN_DATA_DIR/.api_key")"
fi

RECALL_OK=0
if [[ -n "$API_KEY" ]]; then
    TEST_AGENT="arn_switch_verify_$$"
    TEST_CONTENT="ARN model switch verification"

    STORE_RESULT=$(curl -sf -X POST "http://127.0.0.1:$ARN_PORT/v1/memory/store" \
        -H "Content-Type: application/json" \
        -H "X-API-Key: $API_KEY" \
        -d "{\"agent_id\":\"$TEST_AGENT\",\"content\":\"$TEST_CONTENT\",\"importance\":0.5}" \
        2>/dev/null || echo "")

    if [[ -n "$STORE_RESULT" ]]; then
        RECALL_RESULT=$(curl -sf -X POST "http://127.0.0.1:$ARN_PORT/v1/memory/recall" \
            -H "Content-Type: application/json" \
            -H "X-API-Key: $API_KEY" \
            -d "{\"agent_id\":\"$TEST_AGENT\",\"query\":\"model switch verification\",\"top_k\":1}" \
            2>/dev/null || echo "")

        [[ -n "$RECALL_RESULT" ]] && RECALL_OK=1
    fi
fi

if [[ "$RECALL_OK" -eq 1 ]]; then
    ok "Memory recall verified"
else
    warn "Could not verify recall — server may still be loading the $TARGET model"
fi

# ── Final output ──────────────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Switched to $TARGET model."
if [[ -n "$MEMORY_COUNT" ]]; then
    echo "  All $MEMORY_COUNT memories migrated safely."
else
    echo "  All memories migrated safely."
fi
echo "  Memory server restarted."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
